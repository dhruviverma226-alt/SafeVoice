# Copy this file to ".env" and fill in real values.

# Flask session signing key (use a long random string)
SECRET_KEY=change-this-to-a-long-random-string

# Database (default is a local SQLite file; leave as-is for simple setup)
DATABASE_URL=sqlite:///safevoice.db

# Gmail SMTP settings for verification emails.
# MAIL_PASSWORD must be a 16-character Gmail "App Password", NOT your normal password.
# Create one at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=your16charapppassword
MAIL_DEFAULT_SENDER=youremail@gmail.com

# The single administrator account (seeded automatically on first run)
ADMIN_EMAIL=admin@yourcollege.edu
ADMIN_PASSWORD=change-this-admin-password
