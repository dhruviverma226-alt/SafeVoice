6-1-1-1\" data-name=\"logo icon container\">\n                <i class=\"ti ti-shield-check text-white text-lg\" data-kid=\"6-1-1-1-1\" data-name=\"shield check icon\">\n                </i>\n            </div>\n            <span class=\"font-inter font-bold text-xl text-[var(--deep-navy)]\" data-kid=\"6-1-1-2\" data-name=\"brand name\">\n                SafeVoice\n            </span>\n        </div>\n        <div class=\"flex gap-8 text-sm font-medium text-[var(--deep-navy)]/50\" data-kid=\"6-1-2\" data-name=\"footer navigation links\">\n            <a class=\"hover:text-[var(--teal)]\" data-kid=\"6-1-2-1\" data-name=\"privacy policy link\" href=\"#\">\n                Privacy Policy\n            </a>\n            <a class=\"hover:text-[var(--teal)]\" data-kid=\"6-1-2-2\" data-name=\"accessibility link\" href=\"#\">\n                Accessibility\n            </a>\n            <a class=\"hover:text-[var(--teal)]\" data-kid=\"6-1-2-3\" data-name=\"security standards link\" href=\"#\">\n                Security Standards\n            </a>\n        </div>\n        <p class=\"text-sm text-[var(--deep-navy)]/30\" data-kid=\"6-1-3\" data-name=\"copyright notice text\">\n            © 2026 SafeVoice Institutional. All rights reserved.\n        </p>\n    </div>\n</footer>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\">\n</script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\">\n</script>\n<script type=\"module\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Register GSAP Plugins\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Lenis with correct GSAP Sync\n  const lenis = new Lenis();\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Hero Animations (Re-imagined)\n  const heroTl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1.2 } });\n  \n  heroTl.from(\".hero-title\", { autoAlpha: 0, y: 100, rotateX: 30, scale: 0.9 })\n    .from(\".hero-description\", { autoAlpha: 0, y: 20 }, \"-=0.8\")\n    .from(\".hero-btns\", { autoAlpha: 0, scale: 0.8 }, \"-=1\")\n    .from(\".shield-img\", { autoAlpha: 0, filter: \"blur(30px)\", x: 100 }, \"-=1.5\")\n    .from(\".floating-ui-card\", { \n      autoAlpha: 0, \n      y: 50, \n      rotate: 15,\n      stagger: 0.1,\n      ease: \"back.out(2)\"\n    }, \"-=0.5\");\n\n  // Timeline Step Sequential Scroll Animations\n  ScrollTrigger.batch(\".timeline-item\", {\n    onEnter: (batch) => gsap.from(batch, {\n      autoAlpha: 0,\n      y: 100,\n      duration: 1,\n      stagger: 0.15,\n      ease: \"power3.out\"\n    }),\n    start: \"top 85%\"\n  });\n\n  // Activity List Reveal\n  gsap.from(\".activity-row\", {\n    scrollTrigger: {\n      trigger: \".activity-row\",\n      start: \"top 90%\",\n    },\n    autoAlpha: 0,\n    y: 30,\n    stagger: 0.1,\n    duration: 0.8,\n    ease: \"power3.out\"\n  });\n\n  // Navbar Scroll Choreography\n  ScrollTrigger.create({\n    start: \"top -50\",\n    onUpdate: (self) => {\n      const nav = document.getElementById('main-nav');\n      if (self.direction === 1) { // Scrolling down\n        gsap.to(nav, { y: -20, autoAlpha: 0.8, backgroundColor: \"rgba(248, 248, 255, 0.9)\", backdropFilter: \"blur(10px)\", duration: 0.3 });\n      } else { // Scrolling up\n        gsap.to(nav, { y: 0, autoAlpha: 1, backgroundColor: \"transparent\", backdropFilter: \"blur(0px)\", duration: 0.3 });\n      }\n    }\n  });\n</script>\n",
