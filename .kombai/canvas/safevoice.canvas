    "var_dbd83799e506": {
      "type": "variant",
      "label": "Landing Page - Institutional Calm",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 3080,
        "y": 0,
        "w": 1440,
        "h": 800
