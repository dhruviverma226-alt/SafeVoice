      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@600;700;800&family=DM+Sans:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --deep-navy: #0F2537;\n    --teal: #008080;\n    --amber: #FFA000;\n    --ghost-white: #F8F8FF;\n  }\n\n  body {\n    background-color: var(--ghost-white);\n    color: var(--deep-navy);\n    font-family: 'DM Sans', sans-serif;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, .font-inter {\n    font-family: 'Inter', sans-serif;\n  }\n\n  /* Grid Paper Pattern */\n  .grid-bg {\n    background-image: linear-gradient(rgba(15, 37, 55, 0.03) 1px, transparent 1px), \n                      linear-gradient(90deg, rgba(15, 37, 55, 0.03) 1px, transparent 1px);\n    background-size: 32px 32px;\n  }\n\n  .glass-card {\n    border: 1px solid rgba(0, 0, 0, 0.06);\n    background: rgba(255, 255, 255, 0.45);\n    backdrop-filter: blur(12px);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .glass-card::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);\n    z-index: 10;\n  }\n\n  .shield-glow {\n    filter: drop-shadow(0 0 40px rgba(0, 128, 128, 0.2)) drop-shadow(0 0 100px rgba(0, 128, 128, 0.1));\n  }\n\n  .timeline-dot {\n    box-shadow: 0 0 0 6px rgba(0, 128, 128, 0.05);\n  }\n\n  .hero-mask {\n    mask-image: linear-gradient(to bottom, black 80%, transparent);\n  }\n\n  @keyframes float-y {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-20px); }\n  }\n\n  .animate-float {\n    animation: float-y 6s ease-in-out infinite;\n  }\n</style>\n<link data-kid=\"1\" data-name=\"lenis scroll library style\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\"/>\n<!-- Navigation -->\n<nav class=\"fixed top-0 w-full z-50 px-10 py-6 flex justify-between items-center transition-all duration-500\" data-kid=\"2\" data-name=\"main navigation bar\" id=\"main-nav\">\n    <div class=\"flex items-center gap-3\" data-kid=\"2-1\" data-name=\"brand logo container\">\n        <div class=\"w-12 h-12 bg-[var(--deep-navy)] rounded-2xl flex items-center justify-center shadow-lg shadow-[var(--deep-navy)]/10\" data-kid=\"2-1-1\" data-name=\"shield logo background wrapper\">\n            <i class=\"ti ti-shield-half text-white text-2xl\" data-kid=\"2-1-1-1\" data-name=\"shield half icon\">\n            </i>\n        </div>\n        <span class=\"font-inter font-black text-2xl tracking-tighter text-[var(--deep-navy)]\" data-kid=\"2-1-2\" data-name=\"brand name text\">\n            SAFEVOICE\n        </span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-10 font-bold text-sm uppercase tracking-widest text-[var(--deep-navy)]/60\" data-kid=\"2-2\" data-name=\"navigation link container\">\n        <a class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"2-2-1\" data-name=\"protocol navigation link\" href=\"#process\">\n            Protocol\n        </a>\n        <a class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"2-2-2\" data-name=\"integrity navigation link\" href=\"#\">\n            Integrity\n        </a>\n        <a class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"2-2-3\" data-name=\"network navigation link\" href=\"#\">\n            Network\n        </a>\n        <button class=\"px-8 py-3 bg-[var(--deep-navy)] text-white rounded-xl hover:bg-[var(--teal)] transition-all transform hover:scale-105 active:scale-95\" data-kid=\"2-2-4\" data-name=\"system portal call-to-action button\">\n            System Portal\n        </button>\n    </div>\n</nav>\n<!-- Hero Section: Re-imagined Integrated Composition -->\n<section class=\"min-h-screen flex items-center pt-32 pb-20 px-10 md:px-24 grid-bg relative overflow-hidden hero-mask\" data-kid=\"3\" data-name=\"hero section\">\n    <!-- Large Background Typography -->\n    <div class=\"absolute top-1/2 left-0 -translate-y-1/2 font-inter font-black text-[20rem] text-[var(--deep-navy)] opacity-[0.02] select-none pointer-events-none leading-none\" data-kid=\"3-1\" data-name=\"background typography element\">\n        PRIVACY\n    </div>\n    <div class=\"container mx-auto relative z-10\" data-kid=\"3-2\" data-name=\"hero content wrapper\">\n        <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12\" data-kid=\"3-2-1\" data-name=\"hero content layout container\">\n            <!-- Integrated Content -->\n            <div class=\"lg:w-3/5\" data-kid=\"3-2-1-1\" data-name=\"left content column\">\n                <div class=\"mb-10 inline-flex items-center p-1 bg-white border border-[var(--deep-navy)]/5 rounded-2xl shadow-sm\" data-kid=\"3-2-1-1-1\" data-name=\"status badge container\">\n                    <span class=\"px-4 py-1.5 bg-[var(--teal)] text-white rounded-xl text-[10px] font-black uppercase tracking-widest\" data-kid=\"3-2-1-1-1-1\" data-name=\"active status label text\">\n                        Active\n                    </span>\n                    <span class=\"px-4 py-1.5 text-[10px] font-bold text-[var(--deep-navy)]/60 uppercase tracking-widest\" data-kid=\"3-2-1-1-1-2\" data-name=\"version info text\">\n                        Global Encryption Node v4.2\n                    </span>\n                </div>\n                <h1 class=\"font-inter text-7xl md:text-[9rem] font-black text-[var(--deep-navy)] leading-[0.8] mb-10 hero-title tracking-tighter\" data-kid=\"3-2-1-1-2\" data-name=\"hero headline text\">\n                    YOUR VOICE,\n                    <br data-kid=\"3-2-1-1-2-1\" data-name=\"line break\"/>\n                    <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[var(--teal)] to-[var(--deep-navy)]\" data-kid=\"3-2-1-1-2-2\" data-name=\"gradient headline text\">\n                        SAFELY HEARD.\n                    </span>\n                </h1>\n                <div class=\"flex flex-col md:flex-row gap-8 items-start mb-16\" data-kid=\"3-2-1-1-3\" data-name=\"description and action container\">\n                    <p class=\"text-lg md:text-xl text-[var(--deep-navy)]/60 max-w-sm font-medium leading-relaxed hero-description\" data-kid=\"3-2-1-1-3-1\" data-name=\"hero description text\">\n                        The institutional standard for anonymous campus reporting. Built for absolute privacy, engineered for transparency.\n                    </p>\n                    <div class=\"flex-1 flex flex-col gap-4 w-full md:w-auto\" data-kid=\"3-2-1-1-3-2\" data-name=\"cta and proof container\">\n                        <button class=\"px-10 py-6 bg-[var(--teal)] text-white rounded-2xl font-black text-xl hover:bg-[var(--deep-navy)] transition-all shadow-2xl shadow-[var(--teal)]/20 group relative overflow-hidden\" data-kid=\"3-2-1-1-3-2-1\" data-name=\"submit report primary button\">\n                            <span class=\"relative z-10 flex items-center justify-center gap-4\" data-kid=\"3-2-1-1-3-2-1-1\" data-name=\"button content wrapper\">\n                                SUBMIT ANONYMOUS REPORT\n                                <i class=\"ti ti-arrow-up-right text-2xl group-hover:rotate-45 transition-transform\" data-kid=\"3-2-1-1-3-2-1-1-1\" data-name=\"diagonal arrow icon\">\n                                </i>\n                            </span>\n                        </button>\n                        <div class=\"flex items-center gap-4 px-6 opacity-40\" data-kid=\"3-2-1-1-3-2-2\" data-name=\"social proof container\">\n                            <div class=\"flex -space-x-3\" data-kid=\"3-2-1-1-3-2-2-1\" data-name=\"user avatar stack\">\n                                <div class=\"w-8 h-8 rounded-full border-2 border-white bg-gray-200\" data-kid=\"3-2-1-1-3-2-2-1-1\" data-name=\"avatar one\">\n                                </div>\n                                <div class=\"w-8 h-8 rounded-full border-2 border-white bg-gray-300\" data-kid=\"3-2-1-1-3-2-2-1-2\" data-name=\"avatar two\">\n                                </div>\n                                <div class=\"w-8 h-8 rounded-full border-2 border-white bg-gray-400\" data-kid=\"3-2-1-1-3-2-2-1-3\" data-name=\"avatar three\">\n                                </div>\n                            </div>\n                            <span class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"3-2-1-1-3-2-2-2\" data-name=\"social proof stats text\">\n                                12k+ Reports Handled Securely\n                            </span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <!-- Right: Abstract 3D Shield (Enhanced) -->\n            <div class=\"lg:w-2/5 relative flex justify-center items-center h-[500px]\" data-kid=\"3-2-1-2\" data-name=\"right visual column\">\n                <!-- Abstract Shield Object -->\n                <div class=\"relative w-72 h-72 md:w-96 md:h-96 group animate-float\" data-kid=\"3-2-1-2-1\" data-name=\"abstract shield container\">\n                    <div class=\"absolute inset-0 bg-white/40 backdrop-blur-2xl rounded-[5rem] border border-white/60 shadow-inner flex items-center justify-center transform group-hover:rotate-6 transition-transform duration-700\" data-kid=\"3-2-1-2-1-1\" data-name=\"inner shield background\">\n                        <div class=\"absolute inset-4 border border-[var(--teal)]/10 rounded-[4rem]\" data-kid=\"3-2-1-2-1-1-1\" data-name=\"shield border decorative element\">\n                        </div>\n                        <img alt=\"Institutional Shield\" class=\"w-48 h-48 md:w-64 md:h-64 text-[var(--deep-navy)] opacity-10 shield-img shield-glow rotate-[-15deg]\" data-kid=\"3-2-1-2-1-1-2\" data-name=\"shield graphic\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/sbed/shield.svg\"/>\n                    </div>\n                    <!-- Floating UI Elements (Real Interface Mockups) -->\n                    <div class=\"absolute -top-10 -right-10 glass-card p-5 rounded-3xl shadow-2xl w-56 transform rotate-6 z-20 floating-ui-card\" data-kid=\"3-2-1-2-1-2\" data-name=\"secure layer ui mockup card\">\n                        <div class=\"flex items-center gap-4 mb-4\" data-kid=\"3-2-1-2-1-2-1\" data-name=\"mockup header\">\n                            <div class=\"w-10 h-10 bg-green-500/10 text-green-600 rounded-xl flex items-center justify-center\" data-kid=\"3-2-1-2-1-2-1-1\" data-name=\"lock icon wrapper\">\n                                <i class=\"ti ti-shield-lock text-xl\" data-kid=\"3-2-1-2-1-2-1-1-1\" data-name=\"lock icon\">\n                                </i>\n                            </div>\n                            <p class=\"text-xs font-black uppercase tracking-widest text-[var(--deep-navy)]\" data-kid=\"3-2-1-2-1-2-1-2\" data-name=\"mockup label text\">\n                                Secure Layer\n                            </p>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"3-2-1-2-1-2-2\" data-name=\"mockup progress bar\">\n                            <div class=\"h-1.5 w-full bg-gray-100 rounded-full overflow-hidden\" data-kid=\"3-2-1-2-1-2-2-1\" data-name=\"progress bar track\">\n                                <div class=\"h-full bg-green-500 w-3/4 animate-pulse\" data-kid=\"3-2-1-2-1-2-2-1-1\" data-name=\"progress bar fill\">\n                                </div>\n                            </div>\n                            <div class=\"h-1.5 w-1/2 bg-gray-100 rounded-full\" data-kid=\"3-2-1-2-1-2-2-2\" data-name=\"secondary progress bar\">\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"absolute -bottom-10 -left-10 glass-card p-5 rounded-3xl shadow-2xl w-56 transform -rotat