      "html": "<div class=\"bg-white text-[#1E2952] font-['Overpass'] overflow-x-clip selection:bg-[#F4C430] selection:text-[#1E2952]\" data-kid=\"1\" data-name=\"page layout container\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400..900;1,400..900&display=swap');\n        @import url('https://fonts.googleapis.com/css2?family=Overpass:ital,wght@0,100..900;1,100..900&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n        @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n        .font-heading { font-family: 'Schibsted Grotesk', sans-serif; }\n        .font-body { font-family: 'Overpass', sans-serif; }\n\n        .medium-border { border: 2px solid #1E2952; }\n        .hard-offset { box-shadow: 4px 4px 0 0 #1E2952; }\n        .hard-offset-lg { box-shadow: 8px 8px 0 0 #1E2952; }\n        \n        .bottom-accent-saffron { border-bottom: 8px solid #F4C430; }\n        .bottom-accent-turquoise { border-bottom: 8px solid #1CA9C9; }\n        .bottom-accent-indigo { border-bottom: 8px solid #1E2952; }\n\n        /* Custom scrollbar */\n        ::-webkit-scrollbar { width: 12px; }\n        ::-webkit-scrollbar-track { background: #FFFFFF; border-left: 2px solid #1E2952; }\n        ::-webkit-scrollbar-thumb { background: #1E2952; border: 2px solid #FFFFFF; }\n\n        .accordion-content { overflow: hidden; height: 0; }\n        .accordion-item[data-state=\"open\"] .accordion-content { height: auto; }\n    </style>\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 left-0 w-full z-50 bg-white border-b-2 border-[#1E2952] px-6 py-4 flex justify-between items-center\" data-kid=\"1-1\" data-name=\"main navigation bar\">\n        <div class=\"flex items-center gap-2 group cursor-pointer\" data-kid=\"1-1-1\" data-name=\"brand identity container\">\n            <div class=\"bg-[#F4C430] p-1 medium-border group-hover:rotate-12 transition-transform duration-300\" data-kid=\"1-1-1-1\" data-name=\"megaphone icon wrapper\">\n                <i class=\"ti ti-megaphone text-2xl font-black\" data-kid=\"1-1-1-1-1\" data-name=\"megaphone icon\">\n                </i>\n            </div>\n            <span class=\"font-heading font-black text-2xl tracking-tighter uppercase\" data-kid=\"1-1-1-2\" data-name=\"brand name text\">\n                SafeVoice\n            </span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-10 font-black text-sm tracking-widest uppercase\" data-kid=\"1-1-2\" data-name=\"navigation links container\">\n            <a class=\"hover:text-[#1CA9C9] transition-colors\" data-kid=\"1-1-2-1\" data-name=\"guidelines navigation link\" href=\"#guidelines\">\n                Guidelines\n            </a>\n            <a class=\"hover:text-[#1CA9C9] transition-colors\" data-kid=\"1-1-2-2\" data-name=\"security navigation link\" href=\"#security\">\n                Security\n            </a>\n            <a class=\"hover:text-[#1CA9C9] transition-colors\" data-kid=\"1-1-2-3\" data-name=\"faq navigation link\" href=\"#faq\">\n                FAQ\n            </a>\n            <button class=\"bg-[#F4C430] px-6 py-2 medium-border hard-offset active:shadow-none active:translate-x-[2px] active:translate-y-[2px] hover:bg-[#1CA9C9] hover:text-white cursor-pointer\" data-kid=\"1-1-2-4\" data-name=\"access portal button\">\n                Access Portal\n            </button>\n        </div>\n        <button class=\"md:hidden text-2xl\" data-kid=\"1-1-3\" data-name=\"mobile menu button\">\n            <i class=\"ti ti-menu-2\" data-kid=\"1-1-3-1\" data-name=\"menu hamburger icon\">\n            </i>\n        </button>\n    </nav>\n    <main class=\"pt-24\" data-kid=\"1-2\" data-name=\"main content area\">\n        <!-- Section 1: Hero Typographic Maximalism -->\n        <section class=\"min-h-[90vh] flex flex-col justify-center px-6 lg:px-20 py-20 border-b-2 border-[#1E2952]\" data-kid=\"1-2-1\" data-name=\"hero section\">\n            <div class=\"max-w-[1400px] mx-auto w-full\" data-kid=\"1-2-1-1\" data-name=\"hero content wrapper\">\n                <h1 class=\"font-heading font-black text-[clamp(3.5rem,11vw,14rem)] leading-[0.8] tracking-tighter uppercase break-words mb-20\" data-dynamic=\"true\" data-kid=\"1-2-1-1-1\" data-name=\"hero headline text\" data-reason=\"clip-path animated by gsap on load\" id=\"hero-headline\">\n                    Report.\n                    <br data-kid=\"1-2-1-1-1-1\" data-name=\"hero headline line break\"/>\n                    Resolve.\n                    <br data-kid=\"1-2-1-1-1-2\" data-name=\"hero headline line break\"/>\n                    Remain\n                    <span class=\"text-[#1CA9C9]\" data-kid=\"1-2-1-1-1-3\" data-name=\"hero headline anonymous emphasis text\">\n                        Anonymous.\n                    </span>\n                </h1>\n                <!-- #split-bento layout -->\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-stretch\" data-kid=\"1-2-1-1-2\" data-name=\"features bento grid layout\">\n                    <!-- Left column: Subtext and CTA -->\n                    <div class=\"lg:col-span-5 flex flex-col justify-between bg-white medium-border hard-offset-lg p-10 lg:p-14 bottom-accent-saffron\" data-kid=\"1-2-1-1-2-1\" data-name=\"main cta and subtext card\">\n                        <div data-kid=\"1-2-1-1-2-1-1\" data-name=\"call to action text wrapper\">\n                            <p class=\"text-2xl lg:text-4xl font-black leading-[1.1] mb-12 uppercase italic\" data-kid=\"1-2-1-1-2-1-1-1\" data-name=\"hero subtext\">\n                                Institutional Anonymity\n                                <br data-kid=\"1-2-1-1-2-1-1-1-1\" data-name=\"hero subtext line break\"/>\n                                for the Modern\n                                <br data-kid=\"1-2-1-1-2-1-1-1-2\" data-name=\"hero subtext line break\"/>\n                                <span class=\"text-[#1CA9C9]\" data-kid=\"1-2-1-1-2-1-1-1-3\" data-name=\"hero subtext emphasis text\">\n                                    Campus.\n                                </span>\n                            </p>\n                            <div class=\"space-y-6\" data-kid=\"1-2-1-1-2-1-1-2\" data-name=\"call to action buttons container\">\n                                <button class=\"w-full bg-[#1CA9C9] text-white p-6 medium-border hard-offset font-black text-2xl uppercase hover:bg-[#1E2952] cursor-pointer\" data-kid=\"1-2-1-1-2-1-1-2-1\" data-name=\"file report button\">\n                                    File A Report Now\n                                </button>\n                                <a class=\"block text-center font-black uppercase tracking-widest text-sm hover:underline\" data-kid=\"1-2-1-1-2-1-1-2-2\" data-name=\"protocol documentation link\" href=\"#guidelines\">\n                                    Read Anonymity Protocol\n                                </a>\n                            </div>\n                        </div>\n                        <div class=\"mt-12 flex items-center gap-4 text-xs font-black tracking-widest border-t-2 border-[#1E2952] pt-6 opacity-60\" data-kid=\"1-2-1-1-2-1-2\" data-name=\"security protocol metadata container\">\n                            <i class=\"ti ti-lock-square text-2xl\" data-kid=\"1-2-1-1-2-1-2-1\" data-name=\"lock icon\">\n                            </i>\n                            <span data-kid=\"1-2-1-1-2-1-2-2\" data-name=\"protocol version text\">\n                                ZERO IP LOGGING PROTOCOL v4.2\n                            </span>\n                        </div>\n                    </div>\n                    <!-- Right column: 2x2 Feature Previews -->\n                    <div class=\"lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-8\" data-kid=\"1-2-1-1-2-2\" data-name=\"feature preview grid\">\n                        <div class=\"bg-white medium-border hard-offset p-10 group hover:bg-[#1CA9C9] hover:text-white bottom-accent-indigo\" data-kid=\"1-2-1-1-2-2-1\" data-name=\"feature preview card zero trace\">\n                            <div class=\"font-heading font-black text-6xl mb-6 opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"1-2-1-1-2-2-1-1\" data-name=\"feature preview number\">\n                                01\n                            </div>\n                            <h3 class=\"font-heading font-black text-2xl uppercase mb-4 tracking-tight\" data-kid=\"1-2-1-1-2-2-1-2\" data-name=\"feature preview title\">\n                                Zero Trace\n                            </h3>\n                            <p class=\"font-body font-bold leading-snug\" data-kid=\"1-2-1-1-2-2-1-3\" data-name=\"feature preview description\">\n                                Metadata scrubbing strips every digital identifier before submission.\n                            </p>\n                        </div>\n                        <div class=\"bg-white medium-border hard-offset p-10 group hover:bg-[#F4C430] hover:text-[#1E2952] bottom-accent-indigo\" data-kid=\"1-2-1-1-2-2-2\" data-name=\"feature preview card secure dialogue\">\n                            <div class=\"font-heading font-black text-6xl mb-6 opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"1-2-1-1-2-2-2-1\" data-name=\"feature preview number\">\n                                02\n                            </div>\n                            <h3 class=\"font-heading font-black text-2xl uppercase mb-4 tracking-tight\" data-kid=\"1-2-1-1-2-2-2-2\" data-name=\"feature preview title\">\n                                Secure Dialogue\n                            </h3>\n                            <p class=\"font-body font-bold leading-snug\" data-kid=\"1-2-1-1-2-2-2-3\" data-name=\"feature preview description\">\n                                Two-way encrypted chat via temporary 12-digit hash keys.\n                            </p>\n                        </div>\n                        <div class=\"bg-white medium-border hard-offset p-10 group hover:bg-[#1E2952] hover:text-white bottom-accent-indigo\" data-kid=\"1-2-1-1-2-2-3\" data-name=\"feature preview card rapid triage\">\n                            <div class=\"font-heading font-black text-6xl mb-6 opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"1-2-1-1-2-2-3-1\" data-name=\"feature preview number\">\n                                03\n                            </div>\n                            <h3 class=\"font-heading font-black text-2xl uppercase mb-4 tracking-tight\" data-kid=\"1-2-1-1-2-2-3-2\" data-name=\"feature preview title\">\n                                Rapid Triage\n                            </h3>\n                            <p class=\"font-body font-bold leading-snug\" data-kid=\"1-2-1-1-2-2-3-3\" data-name=\"feature preview description\">\n                                Mandated 24-hour review window for all safety-critical reports.\n                            </p>\n                        </div>\n                        <div class=\"bg-[#F4C430] medium-border hard-offset p-10 bottom-accent-indigo flex flex-col justify-between\" data-kid=\"1-2-1-1-2-2-4\" data-name=\"feature preview card archival rigor\">\n                            <div class=\"font-heading font-black text-6xl mb-6 text-[#1E2952]\" data-kid=\"1-2-1-1-2-2-4-1\" data-name=\"feature preview number\">\n                                04\n                            </div>\n                            <div data-kid=\"1-2-1-1-2-2-4-2\" data-name=\"feature preview content\">\n                                <h3 class=\"font-heading font-black text-2xl uppercase mb-4 tracking-tight\" data-kid=\"1-2-1-1-2-2-4-2-1\" data-name=\"feature preview title\">\n                                    Archival Rigor\n                                </h3>\n                                <p class=\"font-body font-bold leading-snug\" data-kid=\"1-2-1-1-2-2-4-2-2\" data-name=\"feature preview description\">\n                                    Hashed records maintained for full campus transparency reporting.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- Section 2: Accordion Guidelines -->\n        <section class=\"py-32 px-6 lg:px-20 bg-white border-b-2 border-[#1E2952]\" data-kid=\"1-2-2\" data-name=\"guidelines accordion section\" id=\"guidelines\">\n            <div class=\"max-w-6xl mx-auto\" data-kid=\"1-2-2-1\" data-name=\"accordion content container\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24 items-end\" data-kid=\"1-2-2-1-1\" data-name=\"accordion header section\">\n                    <div class=\"lg:col-span-7\" data-kid=\"1-2-2-1-1-1\" data-name=\"accordion section title\">\n                        <h2 class=\"font-heading font-black text-6xl lg:text-9xl uppercase tracking-tighter leading-[0.85] mb-8\" data-kid=\"1-2-2-1-1-1-1\" data-name=\"accordion section title line break\">\n                            Rules of\n                            <br data-kid=\"1-2-2-1-1-1-1-1\" data-name=\"accordion section title line break\"/>\n                            <span class=\"text-[#F4C430]\" data-kid=\"1-2-2-1-1-1-1-2\" data-name=\"accordion section title emphasis text\">\n                                Engagement.\n                            </span>\n                        </h2>\n                    </div>\n                    <div class=\"lg:col-span-5\" data-kid=\"1-2-2-1-1-2\" data-name=\"accordion intro description\">\n                        <p class=\"text-2xl font-bold leading-tight uppercase italic border-l-4 border-[#1CA9C9] pl-6 py-2\" data-kid=\"1-2-2-1-1-2-1\" data-name=\"accordion intro text\">\n                            A clear framework for resolving campus conflict without the risk of exposure.\n                        </p>\n                    </div>\n                </div>\n                <!-- #accordion-hero -->\n                <div class=\"space-y-8\" data-kid=\"1-2-2-1-2\" data-name=\"accordion items container\">\n                    <!-- Item 1 -->\n                    <div class=\"accordion-item bg-white medium-border hard-offset overflow-hidden bottom-accent-turquoise\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-1\" data-name=\"scope of reporting accordion item\" data-reason=\"state toggled by script\" data-state=\"open\">\n                        <button class=\"accordion-trigger w-full flex justify-between items-center p-10 cursor-pointer text-left hover:bg-gray-50 transition-colors\" data-kid=\"1-2-2-1-2-1-1\" data-name=\"accordion item trigger button\">\n                            <h4 class=\"font-heading font-black text-3xl lg:text-5xl uppercase tracking-tight\" data-kid=\"1-2-2-1-2-1-1-1\" data-name=\"accordion item title\">\n                                Scope of Reporting\n                            </h4>\n                            <div class=\"accordion-icon w-14 h-14 medium-border flex items-center justify-center bg-white\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-1-1-2\" data-name=\"accordion item icon container\" data-reason=\"rotation animated by script\">\n                                <i class=\"ti ti-chevron-down text-3xl\" data-kid=\"1-2-2-1-2-1-1-2-1\" data-name=\"accordion chevron icon\">\n                                </i>\n                            </div>\n                        </button>\n                        <div class=\"accordion-content px-10 pb-12\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-1-2\" data-name=\"accordion item content\" data-reason=\"height animated by script\">\n                            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-10\" data-kid=\"1-2-2-1-2-1-2-1\" data-name=\"accordion content grid\">\n                                <div class=\"medium-border p-8 bg-gray-50 shadow-[4px_4px_0_0_#1E2952]\" data-kid=\"1-2-2-1-2-1-2-1-1\" data-name=\"academic misconduct list container\">\n                                    <h5 class=\"font-black text-[#1CA9C9] uppercase mb-6 tracking-widest text-lg underline underline-offset-8\" data-kid=\"1-2-2-1-2-1-2-1-1-1\" data-name=\"academic misconduct heading\">\n                                        Academic Misconduct\n                                    </h5>\n                                    <ul class=\"space-y-4 font-black text-xl uppercase italic\" data-kid=\"1-2-2-1-2-1-2-1-1-2\" data-name=\"academic misconduct list\">\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-1-2-1\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-1-2-1-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Exam Tampering\n                                        </li>\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-1-2-2\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-1-2-2-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Mass Plagiarism\n                                        </li>\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-1-2-3\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-1-2-3-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Faculty Coercion\n                                        </li>\n                                    </ul>\n                                </div>\n                                <div class=\"medium-border p-8 bg-[#F4C430] shadow-[4px_4px_0_0_#1E2952]\" data-kid=\"1-2-2-1-2-1-2-1-2\" data-name=\"campus safety list container\">\n                                    <h5 class=\"font-black text-[#1E2952] uppercase mb-6 tracking-widest text-lg underline underline-offset-8\" data-kid=\"1-2-2-1-2-1-2-1-2-1\" data-name=\"campus safety heading\">\n                                        Campus Safety\n                                    </h5>\n                                    <ul class=\"space-y-4 font-black text-xl uppercase italic\" data-kid=\"1-2-2-1-2-1-2-1-2-2\" data-name=\"campus safety list\">\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-2-2-1\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-2-2-1-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Physical Threats\n                                        </li>\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-2-2-2\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-2-2-2-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Title IX Breaches\n                                        </li>\n                                        <li class=\"flex gap-4\" data-kid=\"1-2-2-1-2-1-2-1-2-2-3\" data-name=\"list item\">\n                                            <span data-kid=\"1-2-2-1-2-1-2-1-2-2-3-1\" data-name=\"list marker\">\n                                                >\n                                            </span>\n                                            Facility Misuse\n                                        </li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- Item 2 -->\n                    <div class=\"accordion-item bg-white medium-border hard-offset overflow-hidden bottom-accent-saffron\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-2\" data-name=\"anonymity proof accordion item\" data-reason=\"state toggled by script\" data-state=\"closed\">\n                        <button class=\"accordion-trigger w-full flex justify-between items-center p-10 cursor-pointer text-left hover:bg-gray-50 transition-colors\" data-kid=\"1-2-2-1-2-2-1\" data-name=\"accordion item trigger button\">\n                            <h4 class=\"font-heading font-black text-3xl lg:text-5xl uppercase tracking-tight\" data-kid=\"1-2-2-1-2-2-1-1\" data-name=\"accordion item title\">\n                                Anonymity Proof\n                            </h4>\n                            <div class=\"accordion-icon w-14 h-14 medium-border flex items-center justify-center bg-white\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-2-1-2\" data-name=\"accordion item icon container\" data-reason=\"rotation animated by script\">\n                                <i class=\"ti ti-chevron-down text-3xl\" data-kid=\"1-2-2-1-2-2-1-2-1\" data-name=\"accordion chevron icon\">\n                                </i>\n                            </div>\n                        </button>\n                        <div class=\"accordion-content px-10 pb-12\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-2-2\" data-name=\"accordion item content\" data-reason=\"height animated by script\">\n                            <div class=\"max-w-4xl space-y-8 bg-[#1E2952] text-white p-12 medium-border shadow-[8px_8px_0_0_#1CA9C9]\" data-kid=\"1-2-2-1-2-2-2-1\" data-name=\"anonymity info card\">\n                                <p class=\"text-3xl font-black uppercase leading-none italic\" data-kid=\"1-2-2-1-2-2-2-1-1\" data-name=\"info card headline\">\n                                    Digital Invisibility is\n                                    <span class=\"text-[#F4C430]\" data-kid=\"1-2-2-1-2-2-2-1-1-1\" data-name=\"info card headline emphasis text\">\n                                        Hardcoded.\n                                    </span>\n                                </p>\n                                <p class=\"text-xl font-bold leading-relaxed opacity-90\" data-kid=\"1-2-2-1-2-2-2-1-2\" data-name=\"info card text\">\n                                    SafeVoice routes all traffic through three decentralized scrubbing nodes. Your browser fingerprint is destroyed upon entry. Administrators only receive the raw text and attached evidence—never your identity.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- Item 3 -->\n                    <div class=\"accordion-item bg-white medium-border hard-offset overflow-hidden bottom-accent-indigo\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-3\" data-name=\"resolution sla accordion item\" data-reason=\"state toggled by script\" data-state=\"closed\">\n                        <button class=\"accordion-trigger w-full flex justify-between items-center p-10 cursor-pointer text-left hover:bg-gray-50 transition-colors\" data-kid=\"1-2-2-1-2-3-1\" data-name=\"accordion item trigger button\">\n                            <h4 class=\"font-heading font-black text-3xl lg:text-5xl uppercase tracking-tight\" data-kid=\"1-2-2-1-2-3-1-1\" data-name=\"accordion item title\">\n                                Resolution SLA\n                            </h4>\n                            <div class=\"accordion-icon w-14 h-14 medium-border flex items-center justify-center bg-white\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-3-1-2\" data-name=\"accordion item icon container\" data-reason=\"rotation animated by script\">\n                                <i class=\"ti ti-chevron-down text-3xl\" data-kid=\"1-2-2-1-2-3-1-2-1\" data-name=\"accordion chevron icon\">\n                                </i>\n                            </div>\n                        </button>\n                        <div class=\"accordion-content px-10 pb-12\" data-dynamic=\"true\" data-kid=\"1-2-2-1-2-3-2\" data-name=\"accordion item content\" data-reason=\"height animated by script\">\n                            <div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\" data-kid=\"1-2-2-1-2-3-2-1\" data-name=\"sla stats grid\">\n                                <div class=\"medium-border p-8 bg-white shadow-[4px_4px_0_0_#1CA9C9]\" data-kid=\"1-2-2-1-2-3-2-1-1\" data-name=\"sla stat card 24h\">\n                                    <div class=\"font-black text-5xl mb-2\" data-kid=\"1-2-2-1-2-3-2-1-1-1\" data-name=\"sla stat value\">\n                                        24h\n                                    </div>\n                                    <div class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"1-2-2-1-2-3-2-1-1-2\" data-name=\"sla stat label\">\n                                        Initial Triage\n                                    </div>\n                                </div>\n                                <div class=\"medium-border p-8 bg-white shadow-[4px_4px_0_0_#F4C430]\" data-kid=\"1-2-2-1-2-3-2-1-2\" data-name=\"sla stat card 72h\">\n                                    <div class=\"font-black text-5xl mb-2\" data-kid=\"1-2-2-1-2-3-2-1-2-1\" data-name=\"sla stat value\">\n                                        72h\n                                    </div>\n                                    <div class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"1-2-2-1-2-3-2-1-2-2\" data-name=\"sla stat label\">\n                                        Case Assignment\n                                    </div>\n                                </div>\n                                <div class=\"medium-border p-8 bg-white shadow-[4px_4px_0_0_#1E2952]\" data-kid=\"1-2-2-1-2-3-2-1-3\" data-name=\"sla stat card 14d\">\n                                    <div class=\"font-black text-5xl mb-2\" data-kid=\"1-2-2-1-2-3-2-1-3-1\" data-name=\"sla stat value\">\n                                        14d\n                                    </div>\n                                    <div class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"1-2-2-1-2-3-2-1-3-2\" data-name=\"sla stat label\">\n                                        Target Closure\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- Final CTA -->\n        <section class=\"py-40 px-6 lg:px-20 bg-[#1E2952] text-white overflow-hidden relative\" data-kid=\"1-2-3\" data-name=\"final call to action section\">\n            <div class=\"max-w-5xl mx-auto text-center relative z-10\" data-kid=\"1-2-3-1\" data-name=\"cta content wrapper\">\n                <h2 class=\"font-heading font-black text-6xl lg:text-[12rem] uppercase leading-[0.8] mb-16 tracking-tighter\" data-kid=\"1-2-3-1-1\" data-name=\"cta headline\">\n                    Silence is\n                    <br data-kid=\"1-2-3-1-1-1\" data-name=\"cta headline line break\"/>\n                    <span class=\"text-[#F4C430]\" data-kid=\"1-2-3-1-1-2\" data-name=\"cta headline emphasis text\">\n                        no longer\n                    </span>\n                    <br data-kid=\"1-2-3-1-1-3\" data-name=\"cta headline line break\"/>\n                    mandatory.\n                </h2>\n                <div class=\"flex flex-col items-center gap-8\" data-kid=\"1-2-3-1-2\" data-name=\"cta actions container\">\n                    <button class=\"bg-[#1CA9C9] text-white px-20 py-8 medium-border border-white hard-offset font-black text-3xl uppercase hover:bg-[#F4C430] hover:text-[#1E2952] hover:scale-105 active:scale-95 cursor-pointer transition-transform duration-200\" data-kid=\"1-2-3-1-2-1\" data-name=\"initiate submission button\">\n                        Initiate Submission\n                    </button>\n                    <p class=\"font-black tracking-[0.4em] uppercase text-sm opacity-50\" data-kid=\"1-2-3-1-2-2\" data-name=\"access portal note\">\n                        Authorized Campus Portal Access Only\n                    </p>\n                </div>\n            </div>\n            <i class=\"ti ti-shield-lock absolute top-1/2 left-0 text-[30rem] opacity-5 -translate-y-1/2 -translate-x-1/2 pointer-events-none\" data-kid=\"1-2-3-2\" data-name=\"background shield icon\">\n            </i>\n            <i class=\"ti ti-lock absolute bottom-0 right-0 text-[20rem] opacity-5 translate-y-1/4 translate-x-1/4 pointer-events-none\" data-kid=\"1-2-3-3\" data-name=\"background lock icon\">\n            </i>\n        </section>\n    </main>\n    <!-- Footer -->\n    <footer class=\"py-24 px-6 lg:px-20 border-t-2 border-[#1E2952] bg-white\" data-kid=\"1-3\" data-name=\"site footer section\">\n        <div class=\"max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16\" data-kid=\"1-3-1\" data-name=\"footer navigation grid\">\n            <div class=\"lg:col-span-4\" data-kid=\"1-3-1-1\" data-name=\"footer branding column\">\n                <div class=\"font-heading font-black text-5xl uppercase tracking-tighter mb-6 flex items-center gap-3\" data-kid=\"1-3-1-1-1\" data-name=\"footer brand header\">\n                    <i class=\"ti ti-megaphone text-[#1CA9C9]\" data-kid=\"1-3-1-1-1-1\" data-name=\"footer megaphone icon\">\n                    </i>\n                    SafeVoice\n                </div>\n                <p class=\"max-w-xs font-bold text-lg uppercase leading-tight italic\" data-kid=\"1-3-1-1-2\" data-name=\"footer brand description\">\n                    The authoritative channel for anonymous institutional integrity.\n                </p>\n            </div>\n            <div class=\"lg:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-12 font-black uppercase text-sm tracking-widest\" data-kid=\"1-3-1-2\" data-name=\"footer link groups container\">\n                <div class=\"flex flex-col gap-6\" data-kid=\"1-3-1-2-1\" data-name=\"protocol links group\">\n                    <span class=\"text-[#1CA9C9] border-b-2 border-current pb-2 w-fit\" data-kid=\"1-3-1-2-1-1\" data-name=\"group title\">\n                        Protocol\n                    </span>\n                    <a class=\"hover:text-[#1CA9C9]\" data-kid=\"1-3-1-2-1-2\" data-name=\"encryption link\" href=\"#\">\n                        Encryption\n                    </a>\n                    <a class=\"hover:text-[#1CA9C9]\" data-kid=\"1-3-1-2-1-3\" data-name=\"legality link\" href=\"#\">\n                        Legality\n                    </a>\n                    <a class=\"hover:text-[#1CA9C9]\" data-kid=\"1-3-1-2-1-4\" data-name=\"policy link\" href=\"#\">\n                        Policy\n                    </a>\n                </div>\n                <div class=\"flex flex-col gap-6\" data-kid=\"1-3-1-2-2\" data-name=\"campus links group\">\n                    <span class=\"text-[#F4C430] border-b-2 border-current pb-2 w-fit\" data-kid=\"1-3-1-2-2-1\" data-name=\"group title\">\n                        Campus\n                    </span>\n                    <a class=\"hover:text-[#F4C430]\" data-kid=\"1-3-1-2-2-2\" data-name=\"security link\" href=\"#\">\n                        Security\n                    </a>\n                    <a class=\"hover:text-[#F4C430]\" data-kid=\"1-3-1-2-2-3\" data-name=\"status link\" href=\"#\">\n                        Status\n                    </a>\n                    <a class=\"hover:text-[#F4C430]\" data-kid=\"1-3-1-2-2-4\" data-name=\"admin link\" href=\"#\">\n                        Admin\n                    </a>\n                </div>\n                <div class=\"flex flex-col gap-6\" data-kid=\"1-3-1-2-3\" data-name=\"system links group\">\n                    <span class=\"text-[#1E2952] border-b-2 border-current pb-2 w-fit\" data-kid=\"1-3-1-2-3-1\" data-name=\"group title\">\n                        System\n                    </span>\n                    <a class=\"hover:bg-[#1E2952] hover:text-white px-1\" data-kid=\"1-3-1-2-3-2\" data-name=\"discord link\" href=\"#\">\n                        Discord\n                    </a>\n                    <a class=\"hover:bg-[#1E2952] hover:text-white px-1\" data-kid=\"1-3-1-2-3-3\" data-name=\"github link\" href=\"#\">\n                        GitHub\n                    </a>\n                    <a class=\"hover:bg-[#1E2952] hover:text-white px-1\" data-kid=\"1-3-1-2-3-4\" data-name=\"login link\" href=\"#\">\n                        Login\n                    </a>\n                </div>\n            </div>\n        </div>\n        <div class=\"max-w-[1400px] mx-auto mt-24 pt-10 border-t-4 border-[#1E2952] flex flex-col sm:flex-row justify-between items-center gap-6 text-xs font-black uppercase tracking-widest\" data-kid=\"1-3-2\" data-name=\"footer copyright bar\">\n            <div data-kid=\"1-3-2-1\" data-name=\"copyright text\">\n                © 2024 SAFEVOICE SOLUTIONS CORP.\n            </div>\n            <div class=\"flex gap-8\" data-kid=\"1-3-2-2\" data-name=\"system info container\">\n                <span data-kid=\"1-3-2-2-1\" data-name=\"version string\">\n                    V3.2.0-STARK\n                </span>\n                <span class=\"text-[#1CA9C9]\" data-kid=\"1-3-2-2-2\" data-name=\"security status text\">\n                    SECURED BY HASHFLOW\n                </span>\n            </div>\n        </div>\n    </footer>\n    <!-- GSAP and Libraries -->\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\">\n    </script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\">\n    </script>\n    <script type=\"module\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        // Initialize Lenis\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n\n        // GSAP Animations\n        gsap.registerPlugin(ScrollTrigger);\n\n        // #gsap-mask-wipe\n        gsap.fromTo(\"#hero-headline\", \n            { clipPath: \"inset(0 100% 0 0)\" }, \n            { \n                clipPath: \"inset(0 0 0 0)\", \n                duration: 1.2, \n                ease: \"power4.inOut\",\n                delay: 0.2\n            }\n        );\n\n        // Accordion Logic using MotionJS\n        const accordionItems = document.querySelectorAll('.accordion-item');\n        accordionItems.forEach(item => {\n            const trigger = item.querySelector('.accordion-trigger');\n            const content = item.querySelector('.accordion-content');\n            const icon = item.querySelector('.accordion-icon');\n\n            trigger.addEventListener('click', () => {\n                const isOpen = item.getAttribute('data-state') === 'open';\n                \n                // Close others\n                accordionItems.forEach(otherItem => {\n                    if (otherItem !== item && otherItem.getAttribute('data-state') === 'open') {\n                        const otherContent = otherItem.querySelector('.accordion-content');\n                        const otherIcon = otherItem.querySelector('.accordion-icon');\n                        \n                        animate(otherContent, { height: 0 }, { duration: 0.4, ease: \"circOut\" });\n                        animate(otherIcon, { rotate: 0 }, { duration: 0.3 });\n                        otherItem.setAttribute('data-state', 'closed');\n                    }\n                });\n\n                // Toggle current\n                if (isOpen) {\n                    animate(content, { height: 0 }, { duration: 0.4, ease: \"circOut\" });\n                    animate(icon, { rotate: 0 }, { duration: 0.3 });\n                    item.setAttribute('data-state', 'closed');\n                } else {\n                    animate(content, { height: \"auto\" }, { duration: 0.5, ease: \"backOut\" });\n                    animate(icon, { rotate: 180 }, { duration: 0.3 });\n                    item.setAttribute('data-state', 'open');\n                }\n            });\n        });\n\n        // Entrance animations for elements with .hard-offset\n        // No CSS transition properties on these elements to avoid GSAP conflict\n        gsap.from(\".hard-offset\", {\n            scrollTrigger: {\n                trigger: \".hard-offset\",\n                start: \"top 95%\",\n            },\n            y: 60,\n            opacity: 0,\n            duration: 0.8,\n            stagger: 0.1,\n            ease: \"expo.out\"\n        });\n    </script>\n</div>\n>>>>>>> REPLACE\n",
      "comments": [],
      "created": "2026-07-22T23:38:15.941154+00:00",
