ge\">\n                            REVIEW\n                        </span>\n                        <p class=\"text-[10px] text-[var(--deep-navy)] mt-3 font-black uppercase tracking-widest opacity-60\" data-kid=\"5-1-1-2-2-2-2\" data-name=\"timestamp text\">\n                            18 MINS AGO\n                        </p>\n                    </div>\n                </div>\n                <!-- Activity Row 3 -->\n                <div class=\"activity-row flex items-center justify-between p-6 rounded-[2rem] bg-white border border-[var(--deep-navy)]/5 hover:shadow-xl hover:transition-all cursor-default\" data-kid=\"5-1-1-2-3\" data-name=\"third activity row\">\n                    <div class=\"flex items-center gap-8\" data-kid=\"5-1-1-2-3-1\" data-name=\"row info group\">\n                        <div class=\"w-5 h-5 rounded-lg bg-[var(--deep-navy)]/5 border border-[var(--deep-navy)]/10 flex items-center justify-center\" data-kid=\"5-1-1-2-3-1-1\" data-name=\"row icon container\">\n                            <div class=\"w-1.5 h-1.5 rounded-sm bg-[var(--deep-navy)]/20\" data-kid=\"5-1-1-2-3-1-1-1\" data-name=\"row icon\">\n                            </div>\n                        </div>\n                        <div data-kid=\"5-1-1-2-3-1-2\" data-name=\"row text info\">\n                            <p class=\"font-black text-[var(--deep-navy)] text-xl tracking-tight uppercase\" data-kid=\"5-1-1-2-3-1-2-1\" data-name=\"activity title\">\n                                DATA SYNC COMPLETE\n                            </p>\n                            <p class=\"text-xs text-[var(--deep-navy)] font-bold uppercase tracking-widest opacity-40\" data-kid=\"5-1-1-2-3-1-2-2\" data-name=\"activity category\">\n                                Encrypted Attachment • CASE #9012\n                            </p>\n                        </div>\n                    </div>\n                    <div class=\"text-right\" data-kid=\"5-1-1-2-3-2\" data-name=\"row status group