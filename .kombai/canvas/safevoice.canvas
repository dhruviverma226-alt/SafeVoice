    },
    "var_4357ae073277": {
      "type": "variant",
      "label": "Landing Page - Safe Harbor",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<div class=\"min-h-screen bg-[#F0F8FF] text-[#003262] font-['Atkinson_Hyperlegible'] overflow-x-clip\" data-kid=\"1\" data-name=\"page layout container\" id=\"main-container\">\n    <link data-kid=\"1-1\" data-name=\"lenis scroll stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\"/>\n    <link data-kid=\"1-2\" data-name=\"locomotive scroll stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" rel=\"stylesheet\"/>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;600;700;800&family=Atkinson+Hyperlegible:wght@400;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --oxford-navy: #003262;\n            --mint-leaf: #3EB489;\n            --honey-bronze: #E8AC41;\n            --alice-blue: #F0F8FF;\n        }\n\n        .font-heading { font-family: 'Public Sans', sans-serif; }\n\n        /* Neomorph Raised Effect */\n        .neomorph-raised {\n            background: #ffffff;\n            box-shadow: 20px 20px 60px rgba(0, 50, 98, 0.05), -20px -20px 60px rgba(255, 255, 255, 0.9);\n        }\n\n        /* Frosted Glass */\n        .frosted-glass {\n            background: rgba(255, 255, 255, 0.4);\n            backdrop-filter: blur(16px);\n            -webkit-backdrop-filter: blur(16px);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n\n        /* Neon Glow Mint */\n        .neon-glow-mint {\n            border: 1.5px solid var(--mint-leaf);\n            box-shadow: 0 0 12px rgba(62, 180, 137, 0.2), 0 0 36px rgba(62, 180, 137, 0.06);\n        }\n\n        /* Locomotive Scroll Reveal Stagger */\n        [data-scroll] {\n            opacity: 0;\n            transform: translateY(40px);\n            transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);\n            transition-delay: calc(var(--i, 0) * 120ms);\n        }\n        [data-scroll].is-inview {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .lenis.lenis-smooth {\n            height: auto;\n        }\n    </style>\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6\" data-kid=\"1-3\" data-name=\"main navigation bar\">\n        <div class=\"max-w-7xl mx-auto flex items-center justify-between frosted-glass rounded-2xl px-8 py-4 shadow-sm\" data-kid=\"1-3-1\" data-name=\"navigation container\">\n            <div class=\"flex items-center gap-2\" data-kid=\"1-3-1-1\" data-name=\"brand logo and name group\">\n                <div class=\"w-10 h-10 bg-[var(--oxford-navy)] rounded-xl flex items-center justify-center\" data-kid=\"1-3-1-1-1\" data-name=\"brand logo icon container\">\n                    <i class=\"ti ti-shield-check text-white text-2xl\" data-kid=\"1-3-1-1-1-1\" data-name=\"shield check icon\">\n                    </i>\n                </div>\n                <span class=\"font-heading font-extrabold text-2xl tracking-tight text-[var(--oxford-navy)]\" data-kid=\"1-3-1-1-2\" data-name=\"brand name text\">\n                    SafeVoice\n                </span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-8 font-semibold\" data-kid=\"1-3-1-2\" data-name=\"navigation link group\">\n                <a class=\"hover:text-[var(--mint-leaf)] transition-colors\" data-kid=\"1-3-1-2-1\" data-name=\"our promise link\" href=\"#\">\n                    Our Promise\n                </a>\n                <a class=\"hover:text-[var(--mint-leaf)] transition-colors\" data-kid=\"1-3-1-2-2\" data-name=\"how it works link\" href=\"#\">\n                    How it Works\n                </a>\n                <a class=\"hover:text-[var(--mint-leaf)] transition-colors\" data-kid=\"1-3-1-2-3\" data-name=\"security link\" href=\"#\">\n                    Security\n                </a>\n                <a class=\"px-6 py-2 bg-[var(--oxford-navy)] text-white rounded-xl hover:bg-[var(--oxford-navy)]/90 transition-all\" data-kid=\"1-3-1-2-4\" data-name=\"admin login button\" href=\"#\">\n                    Admin Login\n                </a>\n            </div>\n        </div>\n    </nav>\n    <!-- Section 1: Hero (Bottom Overlay) -->\n    <section class=\"relative h-screen w-full flex flex-col justify-end overflow-hidden\" data-kid=\"1-4\" data-name=\"hero section\" id=\"hero\">\n        <!-- Full-bleed background image -->\n        <div class=\"hero-bg absolute inset-0 z-0\" data-kid=\"1-4-1\" data-name=\"hero background container\">\n            <img alt=\"Serene campus courtyard\" class=\"w-full h-full object-cover\" data-kid=\"1-4-1-1\" data-name=\"hero background image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1762628052475-622104e499a3?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxxdWlldCUyMHBlYWNlZnVsJTIwY2FtcHVzJTIwZ2FyZGVuJTIwb3IlMjBlbXB0eSUyMGNvdXJ0eWFyZCUyMGluJTIwbW9ybmluZyUyMGxpZ2h0fGVufDB8fHx8MTc4NDc2MzQ2OHww&ixlib=rb-4.1.0&q=85&auto=format&w=1920&fit=crop\"/>\n            <div class=\"absolute inset-0 bg-[var(--oxford-navy)]/10\" data-kid=\"1-4-1-2\" data-name=\"hero background overlay\">\n            </div>\n        </div>\n        <!-- Rising Panel -->\n        <div class=\"hero-panel relative z-10 w-full max-w-6xl mx-auto neomorph-raised rounded-t-[60px] p-12 md:p-24 flex flex-col items-center text-center\" data-kid=\"1-4-2\" data-name=\"hero content panel\" id=\"hero-panel\">\n            <span class=\"hero-text inline-block px-4 py-1.5 rounded-full bg-[var(--mint-leaf)]/10 text-[var(--mint-leaf)] font-bold text-sm tracking-widest uppercase mb-6\" data-kid=\"1-4-2-1\" data-name=\"hero category tag\">\n                Securing Campus Trust\n            </span>\n            <h1 class=\"hero-text font-heading text-5xl md:text-8xl font-black text-[var(--oxford-navy)] leading-[1.1] mb-8\" data-kid=\"1-4-2-2\" data-name=\"hero headline text\">\n                SafeVoice: Empowering\n                <br data-kid=\"1-4-2-2-1\" data-name=\"hero headline line break\"/>\n                <span class=\"text-[var(--mint-leaf)]\" data-kid=\"1-4-2-2-2\" data-name=\"hero headline highlighted text\">\n                    Campus Integrity\n                </span>\n            </h1>\n            <p class=\"hero-text text-xl md:text-2xl text-[var(--oxford-navy)]/70 max-w-2xl mx-auto mb-12\" data-kid=\"1-4-2-3\" data-name=\"hero subheadline description\">\n                A secure, anonymous harbor for your concerns. Report issues with confidence, knowing your identity is shielded by military-grade privacy.\n            </p>\n            <div class=\"hero-cta flex flex-col sm:flex-row gap-6\" data-kid=\"1-4-2-4\" data-name=\"hero action button container\">\n                <button class=\"px-10 py-5 bg-[var(--mint-leaf)] text-white rounded-2xl font-bold text-lg hover:bg-[var(--mint-leaf)]/90 transition-all shadow-xl shadow-[var(--mint-leaf)]/20 flex items-center gap-3\" data-kid=\"1-4-2-4-1\" data-name=\"file anonymous report button\">\n                    <i class=\"ti ti-circle-plus text-2xl\" data-kid=\"1-4-2-4-1-1\" data-name=\"plus circle icon\">\n                    </i>\n                    File Anonymous Report\n                </button>\n                <button class=\"px-10 py-5 bg-[var(--oxford-navy)] text-white rounded-2xl font-bold text-lg hover:bg-[var(--oxford-navy)]/90 transition-all shadow-xl shadow-[var(--oxford-navy)]/20 flex items-center gap-3\" data-kid=\"1-4-2-4-2\" data-name=\"track existing case button\">\n                    <i class=\"ti ti-key text-2xl\" data-kid=\"1-4-2-4-2-1\" data-name=\"key icon\">\n                    </i>\n                    Track Existing Case\n                </button>\n            </div>\n        </div>\n    </section>\n    <!-- Section 2: Trust & Security (Asymmetric Bento) -->\n    <section class=\"py-32 px-8 bg-[var(--alice-blue)]\" data-kid=\"1-5\" data-name=\"trust and security section\" id=\"trust\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"1-5-1\" data-name=\"trust section container\">\n            <div class=\"mb-20 text-left\" data-kid=\"1-5-1-1\" data-name=\"trust section heading container\" data-scroll=\"\" style=\"--i: 0\">\n                <h2 class=\"font-heading text-4xl md:text-6xl font-black text-[var(--oxford-navy)] mb-6\" data-kid=\"1-5-1-1-1\" data-name=\"trust section headline\">\n                    Designed for Discretion\n                </h2>\n                <p class=\"text-xl md:text-2xl text-[var(--oxford-navy)]/60 max-w-3xl\" data-kid=\"1-5-1-1-2\" data-name=\"trust section description\">\n                    We built SafeVoice with a single goal: creating a reporting environment where students feel safe, heard, and protected.\n                </p>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-4 md:grid-rows-3 gap-6 auto-rows-[minmax(220px,auto)]\" data-kid=\"1-5-1-2\" data-name=\"bento grid layout\">\n                <!-- Large Card: Zero Tracking (3 cols x 2 rows) -->\n                <div class=\"md:col-span-3 md:row-span-2 neon-glow-mint frosted-glass rounded-[40px] p-12 flex flex-col md:flex-row gap-12 overflow-hidden group relative\" data-kid=\"1-5-1-2-1\" data-name=\"zero tracking feature card\" data-scroll=\"\" style=\"--i: 1\">\n                    <div class=\"md:w-1/2 flex flex-col justify-center relative z-10\" data-kid=\"1-5-1-2-1-1\" data-name=\"zero tracking text content\">\n                        <i class=\"ti ti-eye-off text-[var(--mint-leaf)] text-5xl mb-8\" data-kid=\"1-5-1-2-1-1-1\" data-name=\"eye off icon\">\n                        </i>\n                        <h3 class=\"font-heading text-4xl md:text-5xl font-extrabold text-[var(--oxford-navy)] mb-6\" data-kid=\"1-5-1-2-1-1-2\" data-name=\"zero tracking card title\">\n                            Zero Tracking\n                        </h3>\n                        <p class=\"text-xl text-[var(--oxford-navy)]/70 leading-relaxed mb-8\" data-kid=\"1-5-1-2-1-1-3\" data-name=\"zero tracking card description\">\n                            We don't collect IP addresses, device headers, or metadata. Our architecture ensures that even we can't link a report back to its sender.\n                        </p>\n                        <div class=\"flex flex-wrap gap-4\" data-kid=\"1-5-1-2-1-1-4\" data-name=\"zero tracking badges container\">\n                            <div class=\"flex items-center gap-2 text-[var(--mint-leaf)] bg-white/60 px-4 py-2 rounded-full border border-[var(--mint-leaf)]/20\" data-kid=\"1-5-1-2-1-1-4-1\" data-name=\"anonymization layers badge\">\n                                <i class=\"ti ti-check text-sm\" data-kid=\"1-5-1-2-1-1-4-1-1\" data-name=\"checkmark icon\">\n                                </i>\n                                <span class=\"font-bold text-sm uppercase tracking-wide\" data-kid=\"1-5-1-2-1-1-4-1-2\" data-name=\"badge label\">\n                                    Anonymization Layers\n                                </span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"md:w-1/2 relative bg-[var(--oxford-navy)]/5 rounded-3xl border border-[var(--oxford-navy)]/10 p-8 flex items-center justify-center overflow-hidden\" data-kid=\"1-5-1-2-1-2\" data-name=\"zero tracking visual animation container\">\n                        <div class=\"relative w-full h-full flex items-center justify-center\" data-kid=\"1-5-1-2-1-2-1\" data-name=\"rotating rings container\">\n                            <div class=\"absolute w-40 h-40 border-2 border-dashed border-[var(--mint-leaf)]/30 rounded-full animate-spin-slow\" data-dynamic=\"true\" data-kid=\"1-5-1-2-1-2-1-1\" data-name=\"outer rotating ring\" data-reason=\"rotated continuously by anime.js\">\n                            </div>\n                            <div class=\"absolute w-60 h-60 border-2 border-dashed border-[var(--oxford-navy)]/20 rounded-full animate-reverse-spin\" data-dynamic=\"true\" data-kid=\"1-5-1-2-1-2-1-2\" data-name=\"inner rotating ring\" data-reason=\"rotated continuously by anime.js\">\n                            </div>\n                            <div class=\"z-10 bg-white p-8 rounded-2xl shadow-xl border border-[var(--mint-leaf)]/20 flex flex-col items-center\" data-kid=\"1-5-1-2-1-2-1-3\" data-name=\"secure id badge\">\n                                <i class=\"ti ti-user-x text-5xl text-[var(--mint-leaf)] mb-2\" data-kid=\"1-5-1-2-1-2-1-3-1\" data-name=\"user x icon\">\n                                </i>\n                                <span class=\"font-bold text-[var(--oxford-navy)] tracking-wider\" data-kid=\"1-5-1-2-1-2-1-3-2\" data-name=\"secure id text\">\n                                    SECURE_ID_00x\n                                </span>\n                            </div>\n                            <div class=\"absolute top-4 right-4 p-3 bg-white/90 rounded-xl text-[10px] font-bold text-[var(--honey-bronze)] shadow-sm border border-[var(--honey-bronze)]/20\" data-kid=\"1-5-1-2-1-2-1-4\" data-name=\"header scrubbing status badge\">\n                                Scrubbing Header...\n                            </div>\n                            <div class=\"absolute bottom-4 left-4 p-3 bg-white/90 rounded-xl text-[10px] font-bold text-[var(--mint-leaf)] shadow-sm border border-[var(--mint-leaf)]/20\" data-kid=\"1-5-1-2-1-2-1-5\" data-name=\"proxy status badge\">\n                                Proxy: ACTIVE\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <!-- Card: E2E Encryption (1 col x 1 row) -->\n                <div class=\"md:col-span-1 md:row-span-1 frosted-glass rounded-[40px] p-10 flex flex-col justify-center border-white/50 group hover:border-[var(--mint-leaf)]/50 transition-colors\" data-kid=\"1-5-1-2-2\" data-name=\"e2e encryption feature card\" data-scroll=\"\" style=\"--i: 2\">\n                    <img alt=\"Encryption icon\" class=\"w-10 h-10 mb-6 group-hover:scale-110 transition-transform\" data-kid=\"1-5-1-2-2-1\" data-name=\"encryption icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/padlock.svg\" style=\"filter: brightness(0) saturate(100%) invert(13%) sepia(94%) saturate(2250%) hue-rotate(195deg) brightness(92%) contrast(106%);\">\n                        <h3 class=\"font-heading text-xl font-extrabold text-[var(--oxford-navy)] mb-4\" data-kid=\"1-5-1-2-2-1-1\" data-name=\"e2e encryption card title\">\n                            E2E Encryption\n                        </h3>\n                        <p class=\"text-sm text-[var(--oxford-navy)]/60 leading-relaxed\" data-kid=\"1-5-1-2-2-1-2\" data-name=\"e2e encryption card description\">\n                            AES-256 protocols ensure only assigned officers can read your report.\n                        </p>\n                    </img>\n                </div>\n                <!-- Card: Full Accountability (1 col x 1 row) -->\n                <div class=\"md:col-span-1 md:row-span-1 frosted-glass rounded-[40px] p-10 flex flex-col justify-center border-white/50\" data-kid=\"1-5-1-2-3\" data-name=\"full accountability feature card\" data-scroll=\"\" style=\"--i: 3\">\n                    <i class=\"ti ti-shield-lock text-[var(--honey-bronze)] text-4xl mb-6\" data-kid=\"1-5-1-2-3-1\" data-name=\"shield lock icon\">\n                    </i>\n                    <h3 class=\"font-heading text-xl font-extrabold text-[var(--oxford-navy)] mb-4\" data-kid=\"1-5-1-2-3-2\" data-name=\"full accountability card title\">\n                        Full Accountability\n                    </h3>\n                    <p class=\"text-sm text-[var(--oxford-navy)]/60 leading-relaxed\" data-kid=\"1-5-1-2-3-3\" data-name=\"full accountability card description\">\n                        Immutable logs ensure no report is ignored by campus admins.\n                    </p>\n                </div>\n                <!-- Card: Private Key (2 col x 1 row) -->\n                <div class=\"md:col-span-2 md:row-span-1 bg-[var(--oxford-navy)] rounded-[40px] p-10 flex flex-row items-center gap-8 text-white overflow-hidden relative group hover:bg-[var(--oxford-navy)]/95 transition-all\" data-kid=\"1-5-1-2-4\" data-name=\"unique secure key feature card\" data-scroll=\"\" style=\"--i: 4\">\n                    <div class=\"absolute top-0 right-0 p-8\" data-kid=\"1-5-1-2-4-1\" data-name=\"card accent decorator\">\n                        <div class=\"w-1 h-12 bg-[var(--honey-bronze)] rounded-full opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"1-5-1-2-4-1-1\" data-name=\"accent line\">\n                        </div>\n                    </div>\n                    <div class=\"shrink-0 w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center group-hover:bg-white/10 transition-colors\" data-kid=\"1-5-1-2-4-2\" data-name=\"icon container\">\n                        <i class=\"ti ti-key text-4xl text-[var(--mint-leaf)]\" data-kid=\"1-5-1-2-4-2-1\" data-name=\"key icon\">\n                        </i>\n                    </div>\n                    <div data-kid=\"1-5-1-2-4-3\" data-name=\"card text container\">\n                        <h3 class=\"font-heading text-2xl font-bold mb-2\" data-kid=\"1-5-1-2-4-3-1\" data-name=\"unique key card title\">\n                            Unique Secure Key\n                        </h3>\n                        <p class=\"text-sm text-white/60\" data-kid=\"1-5-1-2-4-3-2\" data-name=\"unique key card description\">\n                            Check status with a 16-character key. No passwords or emails needed.\n                        </p>\n                    </div>\n                </div>\n                <!-- Card: Security Audit (2 col x 1 row) -->\n                <div class=\"md:col-span-2 md:row-span-1 frosted-glass rounded-[40px] p-10 flex flex-row items-center gap-8 border-white/50\" data-kid=\"1-5-1-2-5\" data-name=\"third-party audits feature card\" data-scroll=\"\" style=\"--i: 5\">\n                    <div class=\"shrink-0 w-16 h-16 rounded-2xl bg-[var(--oxford-navy)]/5 flex items-center justify-center text-[var(--oxford-navy)]\" data-kid=\"1-5-1-2-5-1\" data-name=\"icon container\">\n                        <i class=\"ti ti-notes text-4xl\" data-kid=\"1-5-1-2-5-1-1\" data-name=\"notes icon\">\n                        </i>\n                    </div>\n                    <div data-kid=\"1-5-1-2-5-2\" data-name=\"card text container\">\n                        <h3 class=\"font-heading text-2xl font-bold text-[var(--oxford-navy)] mb-2\" data-kid=\"1-5-1-2-5-2-1\" data-name=\"third-party audit card title\">\n                            Third-Party Audits\n                        </h3>\n                        <p class=\"text-sm text-[var(--oxford-navy)]/60\" data-kid=\"1-5-1-2-5-2-2\" data-name=\"third-party audit card description\">\n                            Our privacy architecture is verified monthly by independent security firms.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Section 3: Reporting Categories & Safety Ledger -->\n    <section class=\"py-24 px-8 bg-white\" data-kid=\"1-6\" data-name=\"reporting categories section\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"1-6-1\" data-name=\"reporting section container\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-16\" data-kid=\"1-6-1-1\" data-name=\"reporting content grid\">\n                <!-- Left: Categories -->\n                <div class=\"lg:col-span-2\" data-kid=\"1-6-1-1-1\" data-name=\"categories text container\">\n                    <div data-kid=\"1-6-1-1-1-1\" data-name=\"heading container\" data-scroll=\"\" style=\"--i: 0\">\n                        <h2 class=\"font-heading text-4xl md:text-5xl font-black text-[var(--oxford-navy)] mb-6\" data-kid=\"1-6-1-1-1-1-1\" data-name=\"categories section headline\">\n                            Every Voice Matters\n                        </h2>\n                        <p class=\"text-xl text-[var(--oxford-navy)]/60 mb-12 max-w-xl\" data-kid=\"1-6-1-1-1-1-2\" data-name=\"categories section description\">\n                            SafeVoice handles a wide range of concerns. We ensure your report reaches the right department without exposing your identity.\n                        </p>\n                    </div>\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"1-6-1-1-1-2\" data-name=\"categories grid container\" data-scroll=\"\" style=\"--i: 1\">\n                        <div class=\"p-6 rounded-3xl border border-[var(--oxford-navy)]/5 bg-[var(--alice-blue)]/30 hover:bg-white hover:border-[var(--mint-leaf)] hover:shadow-xl hover:shadow-[var(--mint-leaf)]/5 transition-all flex items-center gap-4 group cursor-pointer\" data-kid=\"1-6-1-1-1-2-1\" data-name=\"harassment category card\">\n                            <i class=\"ti ti-users text-2xl text-[var(--mint-leaf)] group-hover:scale-110 transition-transform\" data-kid=\"1-6-1-1-1-2-1-1\" data-name=\"users icon\">\n                            </i>\n                            <span class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-1-2-1-2\" data-name=\"harassment label\">\n                                Harassment & Title IX\n                            </span>\n                        </div>\n                        <div class=\"p-6 rounded-3xl border border-[var(--oxford-navy)]/5 bg-[var(--alice-blue)]/30 hover:bg-white hover:border-[var(--mint-leaf)] hover:shadow-xl hover:shadow-[var(--mint-leaf)]/5 transition-all flex items-center gap-4 group cursor-pointer\" data-kid=\"1-6-1-1-1-2-2\" data-name=\"campus safety category card\">\n                            <i class=\"ti ti-shield text-2xl text-[var(--mint-leaf)] group-hover:scale-110 transition-transform\" data-kid=\"1-6-1-1-1-2-2-1\" data-name=\"shield icon\">\n                            </i>\n                            <span class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-1-2-2-2\" data-name=\"campus safety label\">\n                                Campus Safety\n                            </span>\n                        </div>\n                        <div class=\"p-6 rounded-3xl border border-[var(--oxford-navy)]/5 bg-[var(--alice-blue)]/30 hover:bg-white hover:border-[var(--mint-leaf)] hover:shadow-xl hover:shadow-[var(--mint-leaf)]/5 transition-all flex items-center gap-4 group cursor-pointer\" data-kid=\"1-6-1-1-1-2-3\" data-name=\"academic integrity category card\">\n                            <i class=\"ti ti-school text-2xl text-[var(--mint-leaf)] group-hover:scale-110 transition-transform\" data-kid=\"1-6-1-1-1-2-3-1\" data-name=\"school icon\">\n                            </i>\n                            <span class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-1-2-3-2\" data-name=\"academic integrity label\">\n                                Academic Integrity\n                            </span>\n                        </div>\n                        <div class=\"p-6 rounded-3xl border border-[var(--oxford-navy)]/5 bg-[var(--alice-blue)]/30 hover:bg-white hover:border-[var(--mint-leaf)] hover:shadow-xl hover:shadow-[var(--mint-leaf)]/5 transition-all flex items-center gap-4 group cursor-pointer\" data-kid=\"1-6-1-1-1-2-4\" data-name=\"facility maintenance category card\">\n                            <i class=\"ti ti-tools text-2xl text-[var(--mint-leaf)] group-hover:scale-110 transition-transform\" data-kid=\"1-6-1-1-1-2-4-1\" data-name=\"tools icon\">\n                            </i>\n                            <span class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-1-2-4-2\" data-name=\"facility maintenance label\">\n                                Facility Maintenance\n                            </span>\n                        </div>\n                    </div>\n                </div>\n                <!-- Right: Safety Ledger (De-slopped stats) -->\n                <div class=\"lg:col-span-1\" data-kid=\"1-6-1-1-2\" data-name=\"safety ledger column\" data-scroll=\"\" style=\"--i: 2\">\n                    <div class=\"neomorph-raised rounded-[40px] p-10 h-full flex flex-col\" data-kid=\"1-6-1-1-2-1\" data-name=\"safety ledger card\">\n                        <h3 class=\"font-heading text-2xl font-bold text-[var(--oxford-navy)] mb-8 flex items-center gap-2\" data-kid=\"1-6-1-1-2-1-1\" data-name=\"safety ledger title\">\n                            <i class=\"ti ti-activity text-[var(--mint-leaf)]\" data-kid=\"1-6-1-1-2-1-1-1\" data-name=\"activity icon\">\n                            </i>\n                            Safety Ledger\n                        </h3>\n                        <div class=\"space-y-10\" data-kid=\"1-6-1-1-2-1-2\" data-name=\"stats container\">\n                            <div class=\"flex items-start gap-6\" data-kid=\"1-6-1-1-2-1-2-1\" data-name=\"stat item 1\">\n                                <div class=\"text-3xl font-black text-[var(--mint-leaf)] shrink-0\" data-kid=\"1-6-1-1-2-1-2-1-1\" data-name=\"stat value 1\">\n                                    100%\n                                </div>\n                                <div data-kid=\"1-6-1-1-2-1-2-1-2\" data-name=\"stat label container 1\">\n                                    <div class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-2-1-2-1-2-1\" data-name=\"stat title 1\">\n                                        Anonymity Rate\n                                    </div>\n                                    <div class=\"text-xs text-[var(--oxford-navy)]/40 mt-1 uppercase tracking-widest\" data-kid=\"1-6-1-1-2-1-2-1-2-2\" data-name=\"stat subtitle 1\">\n                                        Verified by Audit\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"flex items-start gap-6\" data-kid=\"1-6-1-1-2-1-2-2\" data-name=\"stat item 2\">\n                                <div class=\"text-3xl font-black text-[var(--oxford-navy)] shrink-0\" data-kid=\"1-6-1-1-2-1-2-2-1\" data-name=\"stat value 2\">\n                                    24/7\n                                </div>\n                                <div data-kid=\"1-6-1-1-2-1-2-2-2\" data-name=\"stat label container 2\">\n                                    <div class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-2-1-2-2-2-1\" data-name=\"stat title 2\">\n                                        Active Monitoring\n                                    </div>\n                                    <div class=\"text-xs text-[var(--oxford-navy)]/40 mt-1 uppercase tracking-widest\" data-kid=\"1-6-1-1-2-1-2-2-2-2\" data-name=\"stat subtitle 2\">\n                                        Global Operations\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"flex items-start gap-6\" data-kid=\"1-6-1-1-2-1-2-3\" data-name=\"stat item 3\">\n                                <div class=\"text-3xl font-black text-[var(--honey-bronze)] shrink-0\" data-kid=\"1-6-1-1-2-1-2-3-1\" data-name=\"stat value 3\">\n                                    Zero\n                                </div>\n                                <div data-kid=\"1-6-1-1-2-1-2-3-2\" data-name=\"stat label container 3\">\n                                    <div class=\"font-bold text-[var(--oxford-navy)]\" data-kid=\"1-6-1-1-2-1-2-3-2-1\" data-name=\"stat title 3\">\n                                        Data Leaks\n                                    </div>\n                                    <div class=\"text-xs text-[var(--oxford-navy)]/40 mt-1 uppercase tracking-widest\" data-kid=\"1-6-1-1-2-1-2-3-2-2\" data-name=\"stat subtitle 3\">\n                                        Since Inception\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"mt-auto pt-10\" data-kid=\"1-6-1-1-2-1-3\" data-name=\"footer info box\">\n                            <div class=\"p-4 bg-[var(--alice-blue)] rounded-2xl border border-[var(--oxford-navy)]/5 text-sm text-[var(--oxford-navy)]/60\" data-kid=\"1-6-1-1-2-1-3-1\" data-name=\"footer info box content\">\n                                <i class=\"ti ti-info-circle mr-1\" data-kid=\"1-6-1-1-2-1-3-1-1\" data-name=\"info icon\">\n                                </i>\n                                Data updated live from our secure transparency portal.\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Footer -->\n    <footer class=\"bg-[var(--oxford-navy)] text-white py-24 px-8\" data-kid=\"1-7\" data-name=\"footer section\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"1-7-1\" data-name=\"footer content container\">\n            <div class=\"flex flex-col lg:flex-row justify-between gap-16 mb-20\" data-kid=\"1-7-1-1\" data-name=\"footer main grid\">\n                <div class=\"max-w-md\" data-kid=\"1-7-1-1-1\" data-name=\"footer brand section\">\n                    <div class=\"flex items-center gap-3 mb-10\" data-kid=\"1-7-1-1-1-1\" data-name=\"footer brand group\">\n                        <div class=\"w-12 h-12 bg-[var(--mint-leaf)] rounded-2xl flex items-center justify-center\" data-kid=\"1-7-1-1-1-1-1\" data-name=\"footer brand icon container\">\n                            <i class=\"ti ti-shield-check text-white text-3xl\" data-kid=\"1-7-1-1-1-1-1-1\" data-name=\"footer shield check icon\">\n                            </i>\n                        </div>\n                        <span class=\"font-heading font-extrabold text-3xl tracking-tight\" data-kid=\"1-7-1-1-1-1-2\" data-name=\"footer brand name\">\n                            SafeVoice\n                        </span>\n                    </div>\n                    <p class=\"text-white/60 text-xl leading-relaxed\" data-kid=\"1-7-1-1-1-2\" data-name=\"footer description\">\n                        Fostering campus transparency through military-grade anonymity. Your voice is your power; we keep it safe.\n                    </p>\n                </div>\n                <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-12\" data-kid=\"1-7-1-1-2\" data-name=\"footer link grids\">\n                    <div data-kid=\"1-7-1-1-2-1\" data-name=\"privacy link category\">\n                        <h4 class=\"font-bold text-lg mb-6 text-[var(--mint-leaf)] uppercase tracking-widest\" data-kid=\"1-7-1-1-2-1-1\" data-name=\"privacy category title\">\n                            Privacy\n                        </h4>\n                        <ul class=\"space-y-4 text-white/50 font-medium\" data-kid=\"1-7-1-1-2-1-2\" data-name=\"privacy links list\">\n                            <li data-kid=\"1-7-1-1-2-1-2-1\" data-name=\"audit reports link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-1-2-1-1\" data-name=\"audit reports link\" href=\"#\">\n                                    Audit Reports\n                                </a>\n                            </li>\n                            <li data-kid=\"1-7-1-1-2-1-2-2\" data-name=\"trust center link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-1-2-2-1\" data-name=\"trust center link\" href=\"#\">\n                                    Trust Center\n                                </a>\n                            </li>\n                            <li data-kid=\"1-7-1-1-2-1-2-3\" data-name=\"cookie policy link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-1-2-3-1\" data-name=\"cookie policy link\" href=\"#\">\n                                    Cookie Policy\n                                </a>\n                            </li>\n                        </ul>\n                    </div>\n                    <div data-kid=\"1-7-1-1-2-2\" data-name=\"institution link category\">\n                        <h4 class=\"font-bold text-lg mb-6 text-[var(--mint-leaf)] uppercase tracking-widest\" data-kid=\"1-7-1-1-2-2-1\" data-name=\"institution category title\">\n                            Institution\n                        </h4>\n                        <ul class=\"space-y-4 text-white/50 font-medium\" data-kid=\"1-7-1-1-2-2-2\" data-name=\"institution links list\">\n                            <li data-kid=\"1-7-1-1-2-2-2-1\" data-name=\"admin portal link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-2-2-1-1\" data-name=\"admin portal link\" href=\"#\">\n                                    Admin Portal\n                                </a>\n                            </li>\n                            <li data-kid=\"1-7-1-1-2-2-2-2\" data-name=\"partner schools link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-2-2-2-1\" data-name=\"partner schools link\" href=\"#\">\n                                    Partner Schools\n                                </a>\n                            </li>\n                            <li data-kid=\"1-7-1-1-2-2-2-3\" data-name=\"support hub link item\">\n                                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-1-2-2-2-3-1\" data-name=\"support hub link\" href=\"#\">\n                                    Support Hub\n                                </a>\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"col-span-2 sm:col-span-1\" data-kid=\"1-7-1-1-2-3\" data-name=\"join us link category\">\n                        <h4 class=\"font-bold text-lg mb-6 text-[var(--mint-leaf)] uppercase tracking-widest\" data-kid=\"1-7-1-1-2-3-1\" data-name=\"join us category title\">\n                            Join Us\n                        </h4>\n                        <div class=\"flex gap-4\" data-kid=\"1-7-1-1-2-3-2\" data-name=\"social links container\">\n                            <a class=\"w-12 h-12 rounded-2xl border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"1-7-1-1-2-3-2-1\" data-name=\"twitter link\" href=\"#\">\n                                <i class=\"ti ti-brand-x\" data-kid=\"1-7-1-1-2-3-2-1-1\" data-name=\"twitter icon\">\n                                </i>\n                            </a>\n                            <a class=\"w-12 h-12 rounded-2xl border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"1-7-1-1-2-3-2-2\" data-name=\"linkedin link\" href=\"#\">\n                                <i class=\"ti ti-brand-linkedin\" data-kid=\"1-7-1-1-2-3-2-2-1\" data-name=\"linkedin icon\">\n                                </i>\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-white/30\" data-kid=\"1-7-1-2\" data-name=\"copyright and legal section\">\n                <p data-kid=\"1-7-1-2-1\" data-name=\"copyright notice\">\n                    © 2024 SafeVoice Integrity Systems. Standard University Partner.\n                </p>\n                <div class=\"flex gap-10\" data-kid=\"1-7-1-2-2\" data-name=\"legal links container\">\n                    <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-2-2-1\" data-name=\"terms of service link\" href=\"#\">\n                        Terms of Service\n                    </a>\n                    <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-2-2-2\" data-name=\"privacy shield link\" href=\"#\">\n                        Privacy Shield\n                    </a>\n                </div>\n            </div>\n        </div>\n    </footer>\n    <!-- Scripts -->\n    <script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\">\n    </script>\n    <script type=\"module\">\n        import { animate, createTimeline } from 'https://esm.sh/animejs@4';\n\n        document.addEventListener('DOMContentLoaded', () => {\n            // Locomotive Scroll initialization (v5 automatically handles smooth scroll globally)\n            const scroller = new LocomotiveScroll();\n\n            // Anime.js Hero Animation\n            const heroTimeline = createTimeline({\n                defaults: {\n                    easing: 'easeOutExpo',\n                    duration: 1200\n                }\n            });\n\n            heroTimeline\n                .add('.hero-panel', {\n                    translateY: ['100%', '0%'],\n                    opacity: [0, 1],\n                    duration: 1500,\n                    easing: 'easeOutElastic(1, .8)'\n                })\n                .add('.hero-text', {\n                    translateY: [30, 0],\n                    opacity: [0, 1],\n                    delay: (el, i) => i * 150\n                }, '-=800')\n                .add('.hero-cta', {\n                    scale: [0.95, 1],\n                    opacity: [0, 1],\n                    duration: 800\n                }, '-=600');\n\n            // Custom animations for specific items in bento\n            animate('.animate-spin-slow', {\n                rotate: '1turn',\n                duration: 10000,\n                easing: 'linear',\n                loop: true\n            });\n\n            animate('.animate-reverse-spin', {\n                rotate: '-1turn',\n                duration: 15000,\n                easing: 'linear',\n                loop: true\n            });\n        });\n    </script>\n    <style>\n        .animate-spin-slow {\n            animation: none; /* Handled by anime.js for better performance/control */\n        }\n        .animate-reverse-spin {\n            animation: none;\n        }\n    </style>\n</div>\n",
